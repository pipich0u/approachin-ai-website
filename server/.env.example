# 应用配置
NODE_ENV=development
PORT=3210
APP_NAME=approaching-ai-backend

# 日志配置
LOG_LEVEL=error,warn,info,debug

# CORS 配置
CORS_ORIGINS=http://localhost:1234,http://localhost:3000,http://localhost:8080

# 超时配置（毫秒）
REQUEST_TIMEOUT=30000

# JWT 配置（后续使用）
# JWT_SECRET=your-secret-key-change-this-in-production
# JWT_EXPIRES_IN=7d

# 数据库配置（后续使用）
# DB_TYPE=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_USERNAME=root
# DB_PASSWORD=password
# DB_DATABASE=approaching_ai
# DB_SYNCHRONIZE=true
# DB_LOGGING=true

# 飞书机器人Webhook地址
FEISHU_BOT_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxxx-xxxx-xxxx-xxxx
# 飞书机器人签名密钥
FEISHU_BOT_SECRET=xxxxxxxxx